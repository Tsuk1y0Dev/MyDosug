{
	"expo": {
		"name": "MyDosug",
		"slug": "mydosug",
		"version": "0.0.1",
		"orientation": "portrait",
		"icon": "./assets/icon.png",
		"userInterfaceStyle": "light",
		"newArchEnabled": true,
		"splash": {
			"image": "./assets/splash-icon.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.mydosug.app"
		},
		"android": {
			"package": "com.mydosug.app",
			"versionCode": 1,
			"adaptiveIcon": {
				"foregroundImage": "./assets/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"permissions": [
				"ACCESS_FINE_LOCATION",
				"ACCESS_COARSE_LOCATION",
				"INTERNET"
			]
		},
		"web": {
			"favicon": "./assets/favicon.png",
			"bundler": "metro"
		},
		"plugins": [
			[
				"expo-build-properties",
				{
					"android": {
						"compileSdkVersion": 34,
						"targetSdkVersion": 34,
						"buildToolsVersion": "34.0.0"
					}
				}
			]
		],
		"extra": {
			"eas": {
				"projectId": "ccef25eb-2d1b-4677-9acf-e495561048cc"
			}
		},
		"owner": "technopark-development-team"
	}
}
